{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "instructions": [
        ".gemini/GEMINI.md",
        ".gemini/CHARACTERS.md"
    ],
    "plugin": [
        "opencode-gemini-auth@latest",
        "opencode-qwencode-auth@latest",
        "opencode-kilo-auth@latest"
    ],
    "mode": {
        "translate": {
            "thinking_level": "medium",
            "temperature": 1.0,
            "prompt": "You are a professional Japanese to Thai light novel translator. Use natural Thai flow."
        }
    }
}